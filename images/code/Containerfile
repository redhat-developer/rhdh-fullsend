# Containerfile — RHDH custom code agent sandbox image.
#
# Extends the upstream fullsend-code image with tools needed by the
# rhdh-plugins monorepo:
#   - corepack enabled with yarn pre-activated (avoids 10-15 min
#     bootstrap inside read-only /usr sandbox)
#   - Node.js is already in the base image (installed by Claude Code)
#
# Yarn is available on PATH immediately — no runtime corepack setup needed.
# Proxy config is injected at runtime via env files (YARN_HTTP(S)_PROXY).
#
# Build (native arch):
#   podman build -t rhdh-fullsend-code:local \
#     -f images/code/Containerfile images/code/
#
# Build (cross-platform):
#   podman build --platform linux/arm64 -t rhdh-fullsend-code:arm64 \
#     -f images/code/Containerfile images/code/

ARG BASE_IMAGE=ghcr.io/fullsend-ai/fullsend-code:latest
FROM ${BASE_IMAGE}

USER root

# ---------------------------------------------------------------------------
# corepack + yarn — pre-enable corepack and pre-download yarn so agents
# get yarn on PATH with zero startup cost. corepack's own shim lands in
# /usr/local/bin and is the only yarn binary — no wrapper script needed.
#
# COREPACK_HOME=/tmp/corepack — writable under every sandbox policy.
# YARN_HTTP(S)_PROXY is set at runtime via env files, not baked in.
ENV COREPACK_HOME=/tmp/corepack

# Pin yarn to the version rhdh-plugins uses (packageManager in package.json).
# Using yarn@stable would install the latest (4.16.x), but the repo pins 4.12.0
# and corepack would need to re-download at runtime — wasting time and requiring
# write access to the cache.
# chmod -R: v1/ subdirectory tree is created as root during prepare, but the
# sandbox user needs write access (corepack updates lastKnownGood.json at runtime).
RUN mkdir -p "$COREPACK_HOME" \
    && corepack enable \
    && corepack prepare yarn@4.12.0 --activate \
    && yarn --version \
    && chmod -R 777 "$COREPACK_HOME"

# ---------------------------------------------------------------------------
# openspec CLI — spec-driven development tooling.
# Used by agents working on repos with openspec/ directories.
RUN npm install -g @fission-ai/openspec \
    && openspec --version

USER sandbox
